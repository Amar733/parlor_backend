{
  "watch": [
    "server.js",
    "routes/",
    "models/",
    "controllers/",
    "middleware/",
    "services/",
    "ai/",
    ".env"
  ],
  "ext": "js,json",
  "ignore": [
    "node_modules/",
    "uploads/",
    "logs/",
    "*.test.js",
    "*.spec.js"
  ],
  "delay": "1000",
  "env": {
    "NODE_ENV": "development"
  },
  "restartable": "rs",
  "verbose": false
}